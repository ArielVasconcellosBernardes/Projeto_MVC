<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | Projeto MVC</title>
    <link rel="stylesheet" href="/css/login.css">
</head>
<body>
    <main class="login-page">
        <section class="login-card">
            <div class="login-header">
                <span class="login-badge">Projeto MVC</span>
                <h1>Entrar</h1>
                <p>Acesse a aplicacao para navegar pelas paginas do projeto.</p>
            </div>

            <form class="login-form" action="/home" method="GET">
                <label>
                    <span>Nome</span>
                    <input 
                        type="text" 
                        name="nome"
                        placeholder="Digite seu nome"
                        required
                    >
                </label>

                <label>
                    <span>Email</span>
                    <input 
                        type="email" 
                        name="email"
                        placeholder="seu@email.com"
                        required
                    >
                </label>

                <button type="submit">Enviar</button>
            </form>
        </section>
    </main>
</body>
</html>
