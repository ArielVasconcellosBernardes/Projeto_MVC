<%- include('partials/header') %>

<div class="grid md:grid-cols-2 gap-8">

    <!-- FORM -->
    <div class="bg-white p-6 rounded-2xl shadow-lg">

        <h2 class="text-xl font-bold mb-4">
            <%= edit ? "Editar Produto" : "Novo Produto" %>
        </h2>

        <form 
            action="<%= edit ? '/produtos/update/' + edit.id : '/produtos/add' %>" 
            method="POST"
            class="flex flex-col gap-3"
        >

            <input 
                class="border p-3 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none"
                type="text" name="name" placeholder="Nome"
                value="<%= edit ? edit.name : '' %>" required>

            <input 
                class="border p-3 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none"
                type="number" name="price" placeholder="Preço"
                value="<%= edit ? edit.price : '' %>" required>

            <button 
                class="bg-green-600 text-white p-3 rounded-lg font-semibold hover:bg-green-700 transition">
                Salvar
            </button>

        </form>
    </div>

    <!-- LISTA -->
    <div class="bg-white p-6 rounded-2xl shadow-lg">

        <h2 class="text-xl font-bold mb-4">Produtos</h2>

        <div class="flex flex-col gap-3">

            <% products.forEach(p => { %>
                
                <div class="flex justify-between items-center bg-gray-50 p-4 rounded-xl shadow-sm hover:shadow-md transition">

                    <div>
                        <p class="font-semibold text-gray-800">
                            <%= p.name %>
                        </p>
                        <p class="text-gray-500 text-sm">
                            R$ <%= p.price %>
                        </p>
                    </div>

                    <div class="flex gap-2">

                        <a href="/produtos/edit/<%= p.id %>"
                           class="bg-yellow-400 px-3 py-1 rounded-lg text-sm hover:bg-yellow-500 transition">
                           Editar
                        </a>

                        <a href="/produtos/delete/<%= p.id %>"
                           class="bg-red-500 text-white px-3 py-1 rounded-lg text-sm hover:bg-red-600 transition">
                           Excluir
                        </a>

                    </div>

                </div>

            <% }) %>

        </div>

    </div>

</div>

<%- include('partials/footer') %>