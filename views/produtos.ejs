<%- include('partials/header') %>

<h1 class="text-2xl font-bold mb-6">Produtos</h1>

<!-- FORM -->
<form 
    action="<%= edit ? '/produtos/update/' + edit.id : '/produtos/add' %>" 
    method="POST"
    class="flex flex-col gap-3 max-w-md mb-8 border p-6 rounded 
           transition hover:shadow-md"
>

    <input 
        type="text" 
        name="name"
        placeholder="Nome"
        value="<%= edit ? edit.name : '' %>"
        class="border p-2 rounded"
        required
    >

    <input 
        type="number" 
        name="price"
        placeholder="Preço"
        value="<%= edit ? edit.price : '' %>"
        class="border p-2 rounded"
        required
    >

    <textarea 
        name="description"
        placeholder="Descrição"
        class="border p-2 rounded"
    ><%= edit ? edit.description : '' %></textarea>

    <button class="bg-gray-800 text-white p-2 rounded hover:bg-gray-900 transition">
        <%= edit ? "Atualizar" : "Criar" %>
    </button>

</form>

<!-- LISTA -->
<ul class="space-y-4">

    <% products.forEach(p => { %>

        <li class="border p-4 rounded flex justify-between items-center 
                   transition hover:shadow-md hover:-translate-y-1">

            <div>
                <p class="font-semibold"><%= p.name %></p>
                <p class="text-sm">R$ <%= p.price %></p>
                <p class="text-sm text-gray-600">
                    <%= p.description || 'Sem descrição' %>
                </p>
            </div>

            <div class="flex gap-2">

                <a href="/produtos/edit/<%= p.id %>"
                   class="bg-gray-300 px-3 py-1 rounded hover:bg-gray-400 transition">
                   Editar
                </a>

                <a href="/produtos/delete/<%= p.id %>"
                   class="bg-red-500 text-white px-3 py-1 rounded hover:bg-red-600 transition">
                   Excluir
                </a>

            </div>

        </li>

    <% }) %>

</ul>

<%- include('partials/footer') %>