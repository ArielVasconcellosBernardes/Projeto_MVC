<%- include('partials/header') %>

<section class="contact-page">
    <div class="contact-intro">
        <span class="contact-tag">Fale conosco</span>
        <h1>Contato</h1>
        <p>
            Envie sua mensagem para tirar duvidas, sugerir melhorias ou conversar
            sobre o projeto MVC.
        </p>
    </div>

    <form class="contact-form flex flex-col gap-4 max-w-md border p-6 rounded transition hover:shadow-md">

        <label>
            <span>Nome</span>
            <input 
                type="text" 
                placeholder="Seu nome"
                class="border p-2 rounded"
            >
        </label>

        <label>
            <span>Email</span>
            <input 
                type="email" 
                placeholder="seu@email.com"
                class="border p-2 rounded"
            >
        </label>

        <label>
            <span>Mensagem</span>
            <textarea 
                placeholder="Descreva sua mensagem"
                class="border p-2 rounded"
            ></textarea>
        </label>

        <button class="bg-gray-800 text-white p-2 rounded hover:bg-gray-900 transition">
            Enviar mensagem
        </button>

    </form>
</section>

<%- include('partials/footer') %>
