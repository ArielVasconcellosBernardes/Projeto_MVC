<%- include('partials/header') %>

<h1 class="text-2xl font-bold mb-4">Contato</h1>

<form class="flex flex-col gap-4 max-w-md border p-6 rounded 
             transition hover:shadow-md">

    <input 
        type="text" 
        placeholder="Nome"
        class="border p-2 rounded"
    >

    <input 
        type="email" 
        placeholder="Email"
        class="border p-2 rounded"
    >

    <textarea 
        placeholder="Descrição"
        class="border p-2 rounded"
    ></textarea>

    <button class="bg-gray-800 text-white p-2 rounded hover:bg-gray-900 transition">
        Enviar
    </button>

</form>

<%- include('partials/footer') %>